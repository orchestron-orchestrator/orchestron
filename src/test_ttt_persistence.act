TEST_NS = "urn:test:persistence"
SHIFT_NS_A = "urn:test:persistence:shift:a"
SHIFT_NS_B = "urn:test:persistence:shift:b"
SHIFT_NS_C = "urn:test:persistence:shift:c"
REMOVED_NS_OLD = "urn:test:persistence:removed:old"
REMOVED_NS_LIVE = "urn:test:persistence:removed:live"

def q(n: str) -> gdata.Id:
    return gdata.Id(TEST_NS, n)

def qa_shift(n: str) -> gdata.Id:
    return gdata.Id(SHIFT_NS_A, n)

def qb_shift(n: str) -> gdata.Id:
    return gdata.Id(SHIFT_NS_B, n)

def qc_shift(n: str) -> gdata.Id:
    return gdata.Id(SHIFT_NS_C, n)

def qold_removed(n: str) -> gdata.Id:
    return gdata.Id(REMOVED_NS_OLD, n)

def qlive_removed(n: str) -> gdata.Id:
    return gdata.Id(REMOVED_NS_LIVE, n)

def expect[T](t: ?T, errmsg: str) -> T:
    if t is not None:
        return t
    raise ValueError(errmsg)

def is_ttt_db_key(key: bytes) -> bool:
    return key == swdb.META_KEY or key.startswith(swdb.META_KEY + swdb.PATH_SEPARATOR)

def ttt_db_snapshot(read_txn: lmdb.ReadTransaction) -> str:
    codec = swdb.read_key_codec(read_txn)
    cursor = read_txn.cursor()
    lines = []
    kv = cursor.seek_prefix(b"ttt")
    while kv is not None:
        entry = expect(kv, "Missing expected LMDB cursor entry")
        if not is_ttt_db_key(entry.key):
            break
        lines.append(swdb.format_key_debug(entry.key, codec))
        lines.append(entry.value.decode())
        kv = cursor.next()
    return "\n\n".join(lines) + "\n"


