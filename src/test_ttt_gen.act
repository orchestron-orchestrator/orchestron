import testing

import yang
import stratoweave.ttt_gen as ttt_gen
import stratoweave.yang as swyang

ys_cfs = r"""module foo {
  yang-version "1.1";
  namespace "http://example.com/foo";
  prefix "foo";
  import stratoweave {
    prefix sw;
  }
  container c1 {
    list foo {
      key name;

      leaf name {
        type string;
      }

      list bar {
        key name;

        sw:transform respnet.cfs.Foobar;

        leaf name {
          type string;
        }
      }
    }
  }
}
"""

def _test_ttt_gen_cfs_base():
    y = yang.compile([ys_cfs, swyang.stratoweave])
    r = ttt_gen.ttt_prsrc(y, 'respnet.layers.y_0', 'respnet.layers.y_1_loose')
    return r.base

def _test_ttt_gen_cfs_ttt():
    y = yang.compile([ys_cfs, swyang.stratoweave])
    r = ttt_gen.ttt_prsrc(y, 'respnet.layers.y_0', 'respnet.layers.y_1_loose')
    return r.ttt

ys_rfs = r"""module foo {
  yang-version "1.1";
  namespace "http://example.com/foo";
  prefix "foo";
  import stratoweave {
    prefix sw;
  }
  import stratoweave-rfs {
    prefix sw-rfs;
  }
  augment /sw-rfs:rfs {
    list backbone-interface {
      key name;

      sw:rfs-transform respnet.rfs.BBInterface;

      leaf name {
        type string;
      }
      container dynstate {
        sw:dynstate;
        leaf enable-polling {
          type boolean;
        }
      }
      container memory {
        sw:memory;
        leaf allocated-id {
          type uint64;
        }
      }
    }
  }
}
"""

ys_bad_transform_name = r"""module foo {
  yang-version "1.1";
  namespace "http://example.com/foo";
  prefix "foo";
  import stratoweave {
    prefix sw;
  }
  container c1 {
    list foo {
      key name;

      leaf name {
        type string;
      }

      list bar {
        key name;

        sw:transform Foobar;

        leaf name {
          type string;
        }
      }
    }
  }
}
"""

ys_bad_transform_module_name = r"""module foo {
  yang-version "1.1";
  namespace "http://example.com/foo";
  prefix "foo";
  import stratoweave {
    prefix sw;
  }
  container c1 {
    list foo {
      key name;

      leaf name {
        type string;
      }

      list bar {
        key name;

        sw:transform foo-bar.crap;

        leaf name {
          type string;
        }
      }
    }
  }
}
"""

def _test_ttt_gen_rfs_base():
    y = yang.compile([swyang.stratoweave, swyang.rfs, swyang.ietf_inet_types, ys_rfs])
    r = ttt_gen.ttt_prsrc(y, 'respnet.layers.y_1', '')
    return r.base

def _test_ttt_gen_rfs_ttt():
    y = yang.compile([swyang.stratoweave, swyang.rfs, swyang.ietf_inet_types, ys_rfs])
    r = ttt_gen.ttt_prsrc(y, 'respnet.layers.y_1', '')
    return r.ttt

def _test_swdev() -> str:
    y = yang.compile([swyang.stratoweave, swyang.device])
    r = ttt_gen.ttt_prsrc(y, '', '')
    return r.ttt

def _test_ttt_gen_invalid_transform_name():
    y = yang.compile([swyang.stratoweave, ys_bad_transform_name])
    try:
        ttt_gen.ttt_prsrc(y, 'respnet.layers.y_0', 'respnet.layers.y_1_loose')
    except ValueError as e:
        if "Expected a fully qualified transform reference" not in e.error_message:
            raise e

def _test_ttt_gen_invalid_transform_module_name():
    y = yang.compile([swyang.stratoweave, ys_bad_transform_module_name])
    try:
        ttt_gen.ttt_prsrc(y, 'respnet.layers.y_0', 'respnet.layers.y_1_loose')
    except ValueError as e:
        if "not a valid Acton name" not in e.error_message:
            raise e
