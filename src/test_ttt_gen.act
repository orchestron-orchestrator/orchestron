import testing

import yang
import orchestron.ttt_gen as ttt_gen
import orchestron.yang as oyang

ys_cfs = r"""module foo {
  yang-version "1.1";
  namespace "http://example.com/foo";
  prefix "foo";
  import stratoweave {
    prefix sw;
  }
  container c1 {
    list foo {
      key name;

      leaf name {
        type string;
      }

      list bar {
        key name;

        sw:transform respnet.cfs.Foobar;

        leaf name {
          type string;
        }
      }
    }
  }
}
"""

def _test_ttt_gen_cfs_base():
    y = yang.compile([ys_cfs, oyang.stratoweave])
    r = ttt_gen.ttt_prsrc(y, 'respnet.layers.y_0', 'respnet.layers.y_1_loose')
    return r.base

def _test_ttt_gen_cfs_ttt():
    y = yang.compile([ys_cfs, oyang.stratoweave])
    r = ttt_gen.ttt_prsrc(y, 'respnet.layers.y_0', 'respnet.layers.y_1_loose')
    return r.ttt

ys_rfs = r"""module foo {
  yang-version "1.1";
  namespace "http://example.com/foo";
  prefix "foo";
  import stratoweave {
    prefix sw;
  }
  import orchestron-rfs {
    prefix orfs;
  }
  augment /orfs:rfs {
    list backbone-interface {
      key name;

      sw:rfs-transform respnet.rfs.BBInterface;

      leaf name {
        type string;
      }
      container dynstate {
        sw:dynstate;
        leaf enable-polling {
          type boolean;
        }
      }
      container memory {
        sw:memory;
        leaf allocated-id {
          type uint64;
        }
      }
    }
  }
}
"""

ys_bad_transform_name = r"""module foo {
  yang-version "1.1";
  namespace "http://example.com/foo";
  prefix "foo";
  import stratoweave {
    prefix sw;
  }
  container c1 {
    list foo {
      key name;

      leaf name {
        type string;
      }

      list bar {
        key name;

        sw:transform Foobar;

        leaf name {
          type string;
        }
      }
    }
  }
}
"""

ys_bad_transform_module_name = r"""module foo {
  yang-version "1.1";
  namespace "http://example.com/foo";
  prefix "foo";
  import stratoweave {
    prefix sw;
  }
  container c1 {
    list foo {
      key name;

      leaf name {
        type string;
      }

      list bar {
        key name;

        sw:transform foo-bar.crap;

        leaf name {
          type string;
        }
      }
    }
  }
}
"""

def _test_ttt_gen_rfs_base():
    y = yang.compile([oyang.stratoweave, oyang.rfs, oyang.ietf_inet_types, ys_rfs])
    r = ttt_gen.ttt_prsrc(y, 'respnet.layers.y_1', '')
    return r.base

def _test_ttt_gen_rfs_ttt():
    y = yang.compile([oyang.stratoweave, oyang.rfs, oyang.ietf_inet_types, ys_rfs])
    r = ttt_gen.ttt_prsrc(y, 'respnet.layers.y_1', '')
    return r.ttt

def _test_odev() -> str:
    y = yang.compile([oyang.stratoweave, oyang.device])
    r = ttt_gen.ttt_prsrc(y, '', '')
    return r.ttt

def _test_ttt_gen_invalid_transform_name():
    y = yang.compile([oyang.stratoweave, ys_bad_transform_name])
    try:
        ttt_gen.ttt_prsrc(y, 'respnet.layers.y_0', 'respnet.layers.y_1_loose')
    except ValueError as e:
        if "Expected a fully qualified transform reference" not in e.error_message:
            raise e

def _test_ttt_gen_invalid_transform_module_name():
    y = yang.compile([oyang.stratoweave, ys_bad_transform_module_name])
    try:
        ttt_gen.ttt_prsrc(y, 'respnet.layers.y_0', 'respnet.layers.y_1_loose')
    except ValueError as e:
        if "not a valid Acton name" not in e.error_message:
            raise e

ys_linked_leafref_l3vpn = r"""module ietf-l3vpn-svc {
  yang-version "1.1";
  namespace "urn:ietf:params:xml:ns:yang:ietf-l3vpn-svc";
  prefix "l3vpn-svc";
  import stratoweave {
    prefix sw;
  }
  container global-settings {
    sw:transform respnet.cfs.GlobalSettings;

    leaf asn {
      type uint32;
      mandatory true;
    }
  }
  container l3vpn-svc {
    container vpn-services {
      list vpn-service {
        key vpn-id;

        sw:transform respnet.cfs.L3VpnVpnService;

        leaf vpn-id {
          type string;
        }
      }
    }

    container sites {
      list site {
        key site-id;

        sw:transform respnet.cfs.L3VpnSite;
        sw:link global {
          // TODO: fix extension substatements such that *any* valid substatement is parsed
          sw:path /global-settings;
        }

        leaf site-id {
          type string;
        }

        container site-network-accesses {
          list site-network-access {
            key site-network-access-id;

            leaf site-network-access-id {
              type string;
            }

            container vpn-attachment {
              leaf vpn-id {
                sw:link vpn;
                type leafref {
                  path "/l3vpn-svc/vpn-services/vpn-service/vpn-id";
                }
              }
            }
          }
        }
      }
    }
  }
}
"""

def _test_ttt_gen_linked_leafref_l3vpn_base():
    y = yang.compile([ys_linked_leafref_l3vpn, oyang.stratoweave])
    r = ttt_gen.ttt_prsrc(y, 'respnet.layers.y_0', 'respnet.layers.y_1_loose')
    return r.base

def _test_ttt_gen_linked_leafref_l3vpn_ttt():
    y = yang.compile([ys_linked_leafref_l3vpn, oyang.stratoweave])
    r = ttt_gen.ttt_prsrc(y, 'respnet.layers.y_0', 'respnet.layers.y_1_loose')
    return r.ttt
